# PostgreSQL
POSTGRES_PASSWORD=strongpasswordhere

# Django
SECRET_KEY=your-50-char-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Владелец-суперпользователь (создаётся автоматически при старте)
OWNER_USERNAME=your_login
OWNER_PASSWORD=your_very_strong_password
OWNER_EMAIL=your@email.com

# Next.js (public — доступен в браузере)
NEXT_PUBLIC_API_URL=https://yourdomain.com
